# Frontend runtime config (Vite). Copy to .env.development / .env.production.
# All vars are optional; sensible offline defaults apply when unset (see
# src/lib/config.ts).

# Offline UI-dev mode: "1" runs the client with no backend (no REST, no
# WebSocket); chat echoes locally. Set to "0" to attempt a real connection.
# Defaults to offline when unset.
VITE_UI_DEV=1

# Backend REST base (login/register).
VITE_API_ENDPOINT="http://localhost:8080/api"

# Backend WebSocket endpoint.
VITE_WS_ENDPOINT="ws://localhost:8080/ws"

# Cloudflare Turnstile sitekey for the login/register CAPTCHA. The value below
# is Cloudflare's always-passes test key.
VITE_CF_TURNSTILE_SITEKEY="1x00000000000000000000AA"
